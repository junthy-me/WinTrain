WINTRAIN_HTTP_ADDR=:8080

# If omitted, the backend auto-switches to `vision` when it finds a provider API key.
WINTRAIN_ANALYSIS_MODE=vision

# QWen / DashScope OpenAI-compatible provider settings.
# Beijing: https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Virginia: https://dashscope-us.aliyuncs.com/compatible-mode/v1
WINTRAIN_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
WINTRAIN_OPENAI_API_KEY=
WINTRAIN_OPENAI_MODEL=qwen3.5-plus
WINTRAIN_OPENAI_TEMPERATURE=0
WINTRAIN_OPENAI_VIDEO_FPS=2

# Optional fallback aliases also supported by the backend:
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=

# Optional tuning
WINTRAIN_ANALYSIS_TIMEOUT=75s
WINTRAIN_PROVIDER_TIMEOUT=45s
WINTRAIN_KEYFRAME_COUNT=10
WINTRAIN_KEYFRAME_LONG_EDGE=1280
